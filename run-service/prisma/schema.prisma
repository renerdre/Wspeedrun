generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model comments {
  comment_id String   @id @default(uuid()) @db.VarChar(36)
  run_id     String   @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  comment    String   @db.VarChar(255)
  created_at DateTime @db.DateTime(0)
}

model runs {
  run_id          String    @id @default(uuid()) @db.VarChar(36)
  run_category_id String    @db.VarChar(36)
  user_id         String    @db.VarChar(36)
  vod_url         String    @db.VarChar(255)
  run_duration    BigInt
  submitted_at    DateTime  @db.DateTime(0)
  verified_at     DateTime? @db.DateTime(0)
  status          String    @db.VarChar(25)
}
